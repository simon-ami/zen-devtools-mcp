# Zen executable path
ZEN_PATH=/Applications/Zen.app/Contents/MacOS/zen

# Headless mode
ZEN_HEADLESS=false

# Initial page
START_URL=about:blank

# Initial viewport size
VIEWPORT=1280x720

# Accept insecure certificates
ACCEPT_INSECURE_CERTS=false

# Persistent MCP profile
AUTO_PROFILE=true

# Debug logging
DEBUG=
